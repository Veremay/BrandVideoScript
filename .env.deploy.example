APP_NAME=BrandVideo API
API_PREFIX=/api
CORS_ORIGINS=http://YOUR_ECS_PUBLIC_IP
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB=brandvideo
REDIS_URL=redis://redis:6379/0
SILICONFLOW_API_KEY=replace_me
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_DEFAULT_MODEL=Qwen/Qwen2.5-7B-Instruct
SILICONFLOW_ADVANCED_MODEL=Qwen/Qwen2.5-32B-Instruct
SILICONFLOW_REQUEST_TIMEOUT_SECONDS=300
SILICONFLOW_STREAM_TIMEOUT_SECONDS=300
TAVILY_API_KEY=
PROMPT_LANGUAGE=zh
BRAND_WIKI_ROOT=/app/data/brand_wiki
APP_LOG_LEVEL=INFO
PIPELINE_LOG_LEVEL=INFO
ACTIVITY_LOG_ENABLED=true
LLM_STREAM_ECHO=false
