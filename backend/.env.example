APP_NAME=BrandVideo API
API_PREFIX=/api
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=brandvideo
REDIS_URL=redis://localhost:6379/0
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_DEFAULT_MODEL=Qwen/Qwen3-8B
SILICONFLOW_ADVANCED_MODEL=Qwen/Qwen3-32B
# Qwen3 thinking mode is slow; non-stream chat ~90-180s, stream can run longer.
SILICONFLOW_CHAT_TIMEOUT=180
SILICONFLOW_STREAM_TIMEOUT=300
# Tavily: https://docs.tavily.com/welcome — key https://app.tavily.com
TAVILY_API_KEY=
BRAND_WIKI_ROOT=

