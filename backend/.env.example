APP_NAME=BrandVideo API
API_PREFIX=/api
# Comma-separated browser origins for CORS (Next.js dev may use 3001 if 3000 is taken)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=brandvideo
REDIS_URL=redis://localhost:6379/0
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_DEFAULT_MODEL=deepseek-ai/DeepSeek-V3.2
SILICONFLOW_ADVANCED_MODEL=deepseek-ai/DeepSeek-V3.2
# Per-request timeouts (seconds); increase if 32B + thinking still times out
SILICONFLOW_REQUEST_TIMEOUT_SECONDS=300
SILICONFLOW_STREAM_TIMEOUT_SECONDS=600

# Tavily: https://docs.tavily.com/welcome — key https://app.tavily.com
TAVILY_API_KEY=

BRAND_WIKI_ROOT=

# Logging: INFO | DEBUG | WARNING | ERROR
APP_LOG_LEVEL=INFO
PIPELINE_LOG_LEVEL=INFO
# Persist user mutation audit logs (delete/update/accept/reject) to MongoDB activity_logs (1=on, 0=off)
ACTIVITY_LOG_ENABLED=1
# Echo LLM stream tokens to stdout (1=on, 0=off)
LLM_STREAM_ECHO=1